<?xml version="1.0" encoding="UTF-8"?>
<MyGUI type="Layout">
    <!--
        Key Link dialog  ~420 x 310

        Widgets consumed by KeyLinkDialog.cpp:
            TitleLabel      TextBox  - "Link This Machine" / "Machine Linked"
            BodyText        TextBox  - explanation paragraph
            StatusLabel     TextBox  - feedback after action
            ActionButton    Button   - "Link" / "Unlink"
            CancelButton    Button   - back to character select
    -->
    <Widget type="Window" skin="MW_DialogNoTransp" layer="Modal"
            position="0 0 420 310" align="Center" name="_Main">
        <Property key="Visible"  value="false"/>
        <Property key="Caption"  value="Machine Linking"/>

        <Widget type="TextBox" skin="SandText"
                position="16 16 388 24" name="TitleLabel" align="Left Top HStretch">
            <Property key="Caption"    value="Link This Machine"/>
            <Property key="TextAlign"  value="Left VCenter"/>
            <Property key="FontHeight" value="15"/>
        </Widget>

        <!-- EditBox with Static=true is the correct MyGUI widget for word-wrapped read-only text -->
        <Widget type="EditBox" skin="MW_TextEdit"
                position="16 48 388 150" name="BodyText" align="Left Top HStretch">
            <Property key="TextAlign"  value="Left Top"/>
            <Property key="WordWrap"   value="true"/>
            <Property key="MultiLine"  value="true"/>
            <Property key="Static"     value="true"/>
            <Property key="NeedKey"    value="false"/>
            <Property key="FontName"   value="Default"/>
            <Property key="ReadOnly"   value="true"/>
        </Widget>

        <Widget type="TextBox" skin="SandText"
                position="16 208 388 28" name="StatusLabel" align="Left Bottom HStretch">
            <Property key="Caption"    value=""/>
            <Property key="TextAlign"  value="Left VCenter"/>
            <Property key="WordWrap"   value="true"/>
            <Property key="FontHeight" value="14"/>
        </Widget>

        <Widget type="AutoSizedButton" skin="MW_Button"
                position="16 268 80 24" name="CancelButton" align="Left Bottom">
            <Property key="Caption"         value="#{Interface:Cancel}"/>
            <Property key="ExpandDirection" value="Right"/>
        </Widget>
        <Widget type="AutoSizedButton" skin="MW_Button"
                position="308 268 96 24" name="ActionButton" align="Right Bottom">
            <Property key="Caption"         value="Link"/>
            <Property key="ExpandDirection" value="Left"/>
        </Widget>

    </Widget>
</MyGUI>
