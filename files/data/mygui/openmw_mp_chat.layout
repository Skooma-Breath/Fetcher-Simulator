<?xml version="1.0" encoding="UTF-8"?>
<MyGUI type="Layout">
  <Widget type="Window" skin="MW_Window" position="0 0 400 400"
          layer="Windows" name="_Main">
    <Property key="Caption"  value="Chat"/>
    <Property key="MinSize"  value="200 120"/>
    <Property key="Visible"  value="true"/>

    <!-- Exact same layout as the console list_History -->
    <Widget type="EditBox" skin="MW_TextBoxEdit"
            position="5 30 380 303" align="Stretch"
            name="chat_History">
      <Property key="MultiLine"      value="1"/>
      <Property key="ReadOnly"       value="true"/>
      <Property key="FontName"       value="MonoFont"/>
      <Property key="TextAlign"      value="Left Top"/>
      <Property key="TextColour"     value="1 1 1"/>
      <Property key="InvertSelected" value="false"/>
      <Property key="WordWrap"       value="true"/>
      <Property key="MaxTextLength"  value="10000"/>
    </Widget>

    <!-- Exact same layout as the console edit_Command -->
    <Widget type="EditBox" skin="MW_ConsoleCommand"
            position="0 338 384 28" align="HStretch Bottom"
            name="chat_Input">
      <Property key="InvertSelected" value="false"/>
    </Widget>
  </Widget>
</MyGUI>
