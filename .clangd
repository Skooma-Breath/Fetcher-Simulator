# clangd configuration for OpenMW
# Cleaned-up version: removed unsupported keys and ensured proper types.
#
# Notes:
# - Keep compile flags here as safe defaults. clangd will still prefer
#   compile_commands.json when present (which should remain at the repo root).
# - Avoid unsupported keys (some clangd builds have stricter schemas).
# - `Diagnostics.ClangTidy` must be a mapping/dictionary when present; use
#   an empty mapping to enable it without specifying options.

CompileFlags:
  Add:
    - -std=c++20
    - -x
    - c++
    - -DNOMINMAX
    - -DWIN32_LEAN_AND_MEAN
    - -D_UNICODE
    - -DUNICODE
    # Project-level defines that are safe as defaults:
    - -DBUILD_OPENMW
    - -DBUILD_MULTIPLAYER

# Index settings: keep background indexing enabled.
# Avoid specifying keys that some clangd versions don't accept.
Index:
  Background: Build

# Enable clang-tidy diagnostics. clangd expects this to be a mapping.
Diagnostics:
  ClangTidy: {}

# Helpful reminders (not processed by clangd):
# - If clangd still doesn't pick up compile commands for some files, ensure
#   ./compile_commands.json exists at the repository root.
# - If you previously used a "FallbackFlags" key and your clangd rejects it,
#   include the most important fallback flags above in CompileFlags:Add instead.
